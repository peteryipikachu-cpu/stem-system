# 必须与后端使用同一 PostgreSQL 和 Redis。
DATABASE_URL=postgresql+asyncpg://stem:stem@localhost:5432/stem_audit
REDIS_URL=redis://localhost:6379/0

# Worker 与队列
WORKER_ID=worker-1
# The value should cover the combined per-key provider limits across the pool.
WORKER_CONCURRENCY=12
LEASE_SECONDS=3900
POLL_INTERVAL_MS=500
AI_QUEUE_MAX_WAIT_MS=900000

# 模型调用、重试与熔断
AI_MODEL_READ_TIMEOUT_SECONDS=600
AI_DOUBAO_READ_TIMEOUT_SECONDS=3600
AI_RETRY_MAX_ATTEMPTS=1
PROVIDER_CIRCUIT_FAILURE_THRESHOLD=3
PROVIDER_CIRCUIT_WINDOW_SECONDS=300
PROVIDER_CIRCUIT_OPEN_SECONDS=300

# 并发限制；豆包限额按每一把 Key 独立应用。
AI_LIMIT_RULE_CONCURRENCY=4
AI_LIMIT_DOUBAO_CONCURRENCY=3
AI_LIMIT_DOUBAO_DEEP_CONCURRENCY=2
AI_LIMIT_DOUBAO_FAST_CONCURRENCY=1
AI_LIMIT_GEMINI_CONCURRENCY=2
AI_LIMIT_GEMINI_ANSWER_CONCURRENCY=2
AI_LIMIT_GEMINI_SYNTHESIS_CONCURRENCY=1

# 每分钟配额；0 表示不额外限制。
AI_LIMIT_DOUBAO_RPM=0
AI_LIMIT_DOUBAO_TPM=0
AI_LIMIT_GEMINI_RPM=0
AI_LIMIT_GEMINI_TPM=0

# 批处理
BATCH_DEADLINE_TIMEZONE=Asia/Shanghai
BATCH_DEADLINE_HOUR=8
BATCH_MANUAL_REVIEW_CUTOFF_MINUTES=30
BATCH_ESTIMATED_MODEL_P95_SECONDS=60

# 模型供应商；填写实际密钥，切勿提交 .env 文件。
# Comma-separated key pool. Every key has an independent Redis concurrency/RPM/TPM bucket.
DOUBAO_API_KEYS=
# Legacy single-key fallback. Prefer DOUBAO_API_KEYS for new deployments.
DOUBAO_API_KEY=
DOUBAO_MODEL=doubao-seed-2-0-pro-260215
DOUBAO_BASE_URL=https://apiroute.bodenai.net/v1
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-pro-preview
GEMINI_BASE_URL=https://apiroute.bodenai.net/v1
